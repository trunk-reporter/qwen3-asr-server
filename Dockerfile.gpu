# GPU inference image using Python/transformers + CUDA.
# Supports word-level timestamps via ForcedAligner.
# Requires NVIDIA GPU + nvidia-container-toolkit on host.
#
# Build:
#   docker build -f Dockerfile.gpu -t qwen3-asr-server:gpu .
#
# Run (models auto-download on first start):
#   docker run --gpus all -p 8765:8765 \
#     -v ./qwen3-asr-p25-0.6B:/model \
#     -v ./Qwen3-ForcedAligner-0.6B:/aligner \
#     qwen3-asr-server:gpu

# --- Stage 1: Install Python deps ---
FROM python:3.11-slim-bookworm AS builder

RUN pip install --no-cache-dir \
    torch --index-url https://download.pytorch.org/whl/cu124

RUN pip install --no-cache-dir \
    'transformers>=4.50' \
    fastapi \
    'uvicorn[standard]' \
    python-multipart \
    soundfile \
    numpy \
    qwen_asr \
    huggingface_hub

# Strip torch bloat — test suites, C++ headers, static libs,
# and build metadata not needed for inference.
RUN rm -rf \
    /usr/local/lib/python3.11/site-packages/torch/test \
    /usr/local/lib/python3.11/site-packages/torch/include \
    /usr/local/lib/python3.11/site-packages/torch/share \
    /usr/local/lib/python3.11/site-packages/torch/lib/*.a \
    && find /usr/local/lib/python3.11/site-packages -type d -name '__pycache__' -exec rm -rf {} + 2>/dev/null || true \
    && find /usr/local/lib/python3.11/site-packages -name '*.pyc' -delete 2>/dev/null || true

# --- Stage 2: Runtime ---
FROM python:3.11-slim-bookworm

RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/*

# Copy installed packages from builder
COPY --from=builder /usr/local/lib/python3.11/site-packages /usr/local/lib/python3.11/site-packages
COPY --from=builder /usr/local/bin /usr/local/bin

WORKDIR /app

# Copy server + entrypoint
COPY server.py entrypoint.sh ./

ENV INFERENCE_BACKEND=python \
    MODEL_PATH=/model \
    ALIGNER_PATH=/aligner \
    ASR_MODEL_REPO=AuggieActual/qwen3-asr-p25-0.6B \
    ALIGNER_MODEL_REPO=Qwen/Qwen3-ForcedAligner-0.6B \
    DEVICE=auto \
    DTYPE=bfloat16 \
    HOST=0.0.0.0 \
    PORT=8765 \
    WORKERS=1 \
    SPEECH_RMS_THRESHOLD=0.01

EXPOSE 8765

ENTRYPOINT ["/app/entrypoint.sh"]
